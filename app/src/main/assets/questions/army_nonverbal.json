{"id":"a_nv_0001","c":"nonverbal","s":"series","q":"Neeche di gayi figure series mein agla kya aayega?","figs":[{"shapes":[{"type":"circle","fill":"hollow"}]},{"shapes":[{"type":"circle","fill":"solid"}]},{"shapes":[{"type":"halfCircleRight","fill":"solid"}]},{"shapes":[{"type":"halfCircleLeft","fill":"solid"}]}],"fo":[{"shapes":[{"type":"circle","fill":"hollow"}]},{"shapes":[{"type":"circle","fill":"solid"}]},{"shapes":[{"type":"halfCircleTop","fill":"solid"}]},{"shapes":[{"type":"square","fill":"solid"}]}],"a":0,"e":"Pattern mein circle fill hota ja raha hai clockwise direction mein. Pehle hollow, phir solid, phir half-right, phir half-left. Fifth wapis hollow circle hoga — pattern repeat ho raha hai."},
{"id":"a_nv_0002","c":"nonverbal","s":"series","q":"Figure series mein agla figure kya hoga?","figs":[{"shapes":[{"type":"triangle","fill":"solid","rotation":0}]},{"shapes":[{"type":"triangle","fill":"solid","rotation":90}]},{"shapes":[{"type":"triangle","fill":"solid","rotation":180}]},{"shapes":[{"type":"triangle","fill":"solid","rotation":270}]}],"fo":[{"shapes":[{"type":"triangle","fill":"solid","rotation":0}]},{"shapes":[{"type":"triangle","fill":"solid","rotation":45}]},{"shapes":[{"type":"triangle","fill":"solid","rotation":90}]},{"shapes":[{"type":"square","fill":"solid"}]}],"a":0,"e":"Triangle har step mein 90° clock-wise rotate ho raha hai. 270° ke baad wapis 0° par aa jayega, isliye answer solid triangle 0° rotation par hai."},
{"id":"a_nv_0003","c":"nonverbal","s":"series","q":"Series mein agla kya aayega?","figs":[{"shapes":[{"type":"square","fill":"hollow"}]},{"shapes":[{"type":"square","fill":"solid"}]},{"shapes":[{"type":"square","fill":"hollow"}]},{"shapes":[{"type":"square","fill":"solid"}]}],"fo":[{"shapes":[{"type":"square","fill":"hollow"}]},{"shapes":[{"type":"square","fill":"solid"}]},{"shapes":[{"type":"circle","fill":"solid"}]},{"shapes":[{"type":"triangle","fill":"solid"}]}],"a":0,"e":"Square alternately hollow aur solid ho raha hai. Hollow ke baad solid aata hai. Isliye next hollow square hoga."},
{"id":"a_nv_0004","c":"nonverbal","s":"series","q":"Series ka agla figure kya hoga?","figs":[{"shapes":[{"type":"triangle","fill":"solid","rotation":0}]},{"shapes":[{"type":"triangle","fill":"hollow","rotation":0}]},{"shapes":[{"type":"triangle","fill":"solid","rotation":180}]},{"shapes":[{"type":"triangle","fill":"hollow","rotation":180}]}],"fo":[{"shapes":[{"type":"triangle","fill":"solid","rotation":0}]},{"shapes":[{"type":"triangle","fill":"hollow","rotation":180}]},{"shapes":[{"type":"square","fill":"solid"}]},{"shapes":[{"type":"triangle","fill":"solid","rotation":180}]}],"a":0,"e":"Pattern: solid up, hollow up, solid down, hollow down. Phir repeat hoga — next solid up triangle hoga."},
{"id":"a_nv_0005","c":"nonverbal","s":"classification","q":"In mein se kaunsa figure alag hai?","fo":[{"shapes":[{"type":"triangle","fill":"solid"}]},{"shapes":[{"type":"square","fill":"solid"}]},{"shapes":[{"type":"circle","fill":"solid"}]},{"shapes":[{"type":"pentagon","fill":"hollow"}]}],"a":3,"e":"Pehle teeno solid hain. Chautha (pentagon) hollow hai — isliye woh alag hai."},
{"id":"a_nv_0006","c":"nonverbal","s":"analogy","q":"Dhyan se dekhein: pehla figure solid hai, doosra hollow. Isi tarah ka pattern lagayein.","figs":[{"shapes":[{"type":"triangle","fill":"solid"}]},{"shapes":[{"type":"triangle","fill":"hollow"}]}],"fo":[{"shapes":[{"type":"square","fill":"solid"}]},{"shapes":[{"type":"square","fill":"hollow"}]},{"shapes":[{"type":"circle","fill":"solid"}]},{"shapes":[{"type":"square","fill":"solid","rotation":45}]}],"a":1,"e":"Pehle pair mein solid triangle → hollow triangle. Isi analogy se square ka pair banega: solid square → hollow square."},
{"id":"a_nv_0007","c":"nonverbal","s":"mirror","q":"Neeche di gayi figure ka mirror image (left-right reversed) kya hoga?","figs":[{"shapes":[{"type":"halfCircleRight","fill":"solid"}]}],"fo":[{"shapes":[{"type":"halfCircleLeft","fill":"solid"}]},{"shapes":[{"type":"halfCircleRight","fill":"solid"}]},{"shapes":[{"type":"halfCircleTop","fill":"solid"}]},{"shapes":[{"type":"halfCircleBottom","fill":"solid"}]}],"a":0,"e":"Mirror image mein left-right reverse hota hai. Half-circle right ki mirror image half-circle left banegi."},
{"id":"a_nv_0008","c":"nonverbal","s":"rotation","q":"L-shape ko 90° clock-wise rotate kiya gaya hai. Agla kya hoga?","figs":[{"shapes":[{"type":"cross","fill":"solid"}]}],"fo":[{"shapes":[{"type":"cross","fill":"solid","rotation":90}]},{"shapes":[{"type":"cross","fill":"solid","rotation":0}]},{"shapes":[{"type":"cross","fill":"solid","rotation":45}]},{"shapes":[{"type":"square","fill":"solid"}]}],"a":0,"e":"90° clock-wise rotation ke baad cross 90° par aa jayega. Pattern repeat karta hai — 4 rotations ke baad original par wapas."},
{"id":"a_nv_0009","c":"nonverbal","s":"series","q":"Dots ki series mein agla kya aayega?","figs":[{"shapes":[{"type":"dot","count":1}]},{"shapes":[{"type":"dot","count":2}]},{"shapes":[{"type":"dot","count":3}]},{"shapes":[{"type":"dot","count":4}]}],"fo":[{"shapes":[{"type":"dot","count":5}]},{"shapes":[{"type":"dot","count":4}]},{"shapes":[{"type":"dot","count":6}]},{"shapes":[{"type":"dot","count":3}]}],"a":0,"e":"Dots 1, 2, 3, 4 ki series hai. Har step mein ek dot barh raha hai. Isliye next 5 dots honge."},
{"id":"a_nv_0010","c":"nonverbal","s":"series","q":"Series mein agla kya hoga?","figs":[{"shapes":[{"type":"dotGrid","count":1}]},{"shapes":[{"type":"dotGrid","count":4}]},{"shapes":[{"type":"dotGrid","count":9}]},{"shapes":[{"type":"dotGrid","count":16}]}],"fo":[{"shapes":[{"type":"dotGrid","count":25}]},{"shapes":[{"type":"dotGrid","count":20}]},{"shapes":[{"type":"dotGrid","count":24}]},{"shapes":[{"type":"dotGrid","count":36}]}],"a":0,"e":"Dots perfect squares ki series mein hain: 1²=1, 2²=4, 3²=9, 4²=16. Next 5²=25 hoga."},
{"id":"a_nv_0011","c":"nonverbal","s":"analogy","q":"Solid square : hollow square :: solid circle : ?","figs":[{"shapes":[{"type":"square","fill":"solid"}]},{"shapes":[{"type":"square","fill":"hollow"}]},{"shapes":[{"type":"circle","fill":"solid"}]}],"fo":[{"shapes":[{"type":"circle","fill":"hollow"}]},{"shapes":[{"type":"circle","fill":"solid"}]},{"shapes":[{"type":"square","fill":"hollow"}]},{"shapes":[{"type":"triangle","fill":"hollow"}]}],"a":0,"e":"Solid → hollow ka pattern lagayein. Solid circle ka counterpart hollow circle hoga."},
{"id":"a_nv_0012","c":"nonverbal","s":"classification","q":"Alag wala figure chunein.","fo":[{"shapes":[{"type":"pentagon","fill":"solid"}]},{"shapes":[{"type":"hexagon","fill":"solid"}]},{"shapes":[{"type":"triangle","fill":"solid"}]},{"shapes":[{"type":"circle","fill":"solid"}]}],"a":3,"e":"Pehle teeno straight sides wale polygons hain. Circle ke koi straight side nahi — isliye woh alag hai."},
{"id":"a_nv_0013","c":"nonverbal","s":"series","q":"Series ka agla figure?","figs":[{"shapes":[{"type":"diamond","fill":"solid","rotation":0}]},{"shapes":[{"type":"diamond","fill":"solid","rotation":45}]},{"shapes":[{"type":"diamond","fill":"solid","rotation":90}]},{"shapes":[{"type":"diamond","fill":"solid","rotation":135}]}],"fo":[{"shapes":[{"type":"diamond","fill":"solid","rotation":180}]},{"shapes":[{"type":"diamond","fill":"solid","rotation":0}]},{"shapes":[{"type":"square","fill":"solid"}]},{"shapes":[{"type":"diamond","fill":"hollow","rotation":180}]}],"a":0,"e":"Diamond har step mein 45° rotate ho raha hai. 135° ke baad 180° par aa jayega."},
